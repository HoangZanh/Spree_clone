<% if @homepage %>
    <% @homepage.cms_sections.each do |section| %>
      <%= build_section(section) %>
    <% end %>
<% else %>
  <%# === Trang chủ tùy chỉnh: Hiển thị sản phẩm nổi bật === %>
  <div class="container my-5">
    <div class="row text-center mb-4">
      <div class="col-12">
        <h1 class="display-5 fw-bold">🚗 Cửa hàng Phụ kiện Xe hơi</h1>
        <p class="lead text-muted">Chào mừng bạn đến với SpreeCarStore – Phụ kiện xe hơi chất lượng cao</p>
      </div>
    </div>

    <div class="row">
      <% @products = Spree::Product.includes(:master).limit(8) if @products.blank? %>
      <% @products.each do |product| %>
        <div class="col-md-3 col-sm-6 mb-4">
          <div class="card h-100 shadow-sm">
            <% if product.images.any? %>
              <%= image_tag main_app.url_for(product.images.first.attachment), class: 'card-img-top', style: 'height: 200px; object-fit: cover;' %>
            <% else %>
              <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                <span class="text-muted">🚗 Không có ảnh</span>
              </div>
            <% end %>
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= product.name %></h5>
              <p class="card-text text-danger fw-bold mt-auto">
                <%= number_to_currency(product.price, unit: '₫', precision: 0, delimiter: '.', format: '%n %u') %>
              </p>
              <%= link_to 'Xem chi tiết', spree.product_path(product), class: 'btn btn-primary btn-sm mt-2' %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @products.blank? %>
      <div class="alert alert-info text-center">
        Chưa có sản phẩm nào. Hãy vào <a href="/admin/products/new">Admin</a> để thêm sản phẩm!
      </div>
    <% end %>
  </div>
<% end %>

<%= render "spree/shared/cms/pages/edit_mode", edit_mode: @edit_mode %>

<div class="container text-center py-4 border-top mt-5">
  <p>Thực hiện bởi: <strong>Đặng Dương Thanh Quang (23120344)</strong> & Nguyễn Hoàng Danh (23120028)</p>
  <p>Mã nguồn mở: <strong>Spree Commerce / Ruby on Rails</strong></p>
  <p>Đăng ký Host tại: <a href="https://render.com" target="_blank">Render.com</a></p>
</div>
