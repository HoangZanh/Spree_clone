# ====================================================================
# NHÓM 1: CẤU HÌNH DÀNH CHO RUBY ON RAILS (RẤT QUAN TRỌNG)
# ====================================================================

# Bỏ qua các cấu hình riêng của Bundler (quản lý Gem) trên máy cá nhân
.bundle/

# Bỏ qua toàn bộ file nhật ký (log) và file tạm (tmp) để tránh làm nặng Repo
log/
tmp/

# Nhưng vẫn giữ lại các file .keep để Git không xóa mất thư mục rỗng
!log/.keep
!tmp/.keep

# Bỏ qua các file định danh tiến trình (pids) để tránh xung đột khi bật server
tmp/pids/
!tmp/pids/
!tmp/pids/.keep

# Bỏ qua dữ liệu ảnh/file do người dùng upload lên (để nhẹ máy khi clone)
storage/
!storage/.keep
tmp/storage/
!tmp/storage/
!tmp/storage/.keep

# Bỏ qua các file giao diện đã được biên dịch (CSS/JS rác trong public)
public/assets/

# QUAN TRỌNG: Tuyệt đối không đẩy chìa khóa bảo mật lên GitHub
config/master.key
config/credentials/*.key


# ====================================================================
# NHÓM 2: CẤU HÌNH CHO C# / .NET / VISUAL STUDIO (NẾU CÓ DÙNG)
# ====================================================================

# Bỏ qua các file cấu hình giao diện cá nhân của Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Bỏ qua kết quả biên dịch (Build) của C# để tránh xung đột phiên bản
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/

# Lưu ý: Không chặn thư mục [Bb]in/ của Rails vì chứa script khởi động server
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Bỏ qua các gói thư viện NuGet của C#
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# Bỏ qua cấu hình của trình soạn thảo JetBrains Rider
.idea/

# Bỏ qua các file tùy chỉnh riêng của người dùng
*.rsuser


# ====================================================================
# NHÓM 3: CÁC FILE DO HỆ ĐIỀU HÀNH TỰ SINH RA (RÁC HỆ THỐNG)
# ====================================================================

# File rác của Windows (ảnh thumb, cấu hình folder)
Thumbs.db
ehthumbs.db
Desktop.ini

# File rác của macOS
.DS_Store

# File tài liệu hướng dẫn nội bộ (không cần đẩy lên web)
rule.md